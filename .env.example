# HubSpot auth: set ONE of these
PRIVATE_APP_TOKEN=
HUBSPOT_API_KEY=

# HubSpot owner ID for task assignment filter
USER_ID=

# Digest recipient
EMAIL_TO=

# Sender identity (used by nodemailer)
EMAIL_FROM=

# SMTP settings for nodemailer
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional runtime settings
HUBSPOT_BASE_URL=https://api.hubapi.com
MAX_CONCURRENCY=5
MAX_RETRIES=5
REQUEST_TIMEOUT_MS=15000
CRON_SCHEDULE=0 9 * * 1
