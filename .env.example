# HubSpot auth: set ONE of these
PRIVATE_APP_TOKEN=
HUBSPOT_API_KEY=

# HubSpot owner ID for task assignment filter
USER_ID=

# Digest recipient
EMAIL_TO=

# Sender identity used by Resend (must be verified in Resend)
EMAIL_FROM=

# Resend API key
RESEND_API_KEY=

# HTTP server settings
PORT=3000

# Shared secret required by cron-job.org webhook calls
DIGEST_TRIGGER_SECRET=

# Optional runtime settings
HUBSPOT_BASE_URL=https://api.hubapi.com
MAX_CONCURRENCY=5
MAX_RETRIES=5
REQUEST_TIMEOUT_MS=15000

# Delivery schedule is configured in cron-job.org (weekly day/time/timezone).
